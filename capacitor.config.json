{
  "appId": "com.educationacademy.app",
  "appName": "Education Academy",
  "webDir": "dist-app",
  "backgroundColor": "#FFF4E6",
  "server": {
    "androidScheme": "https"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1200,
      "launchAutoHide": true,
      "backgroundColor": "#FFF4E6",
      "androidScaleType": "CENTER_CROP",
      "showSpinner": false
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#FFF4E6"
    }
  }
}
