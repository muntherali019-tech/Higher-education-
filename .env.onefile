# Single-file build (`npm run build:onefile` -> dist-onefile/index.html).
# A self-contained app you can open from disk or drop on any static host.
VITE_PLATFORM=web
VITE_BILLING=mock
# The single file has no server of its own. To make the AI tutor work, point it at
# your deployed API (from the website deploy). Leave blank for an offline-only demo.
# VITE_API_BASE=https://your-address/api
